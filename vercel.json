{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/category/([a-z0-9-]+)/?",
      "dest": "/category.php?slug=$1"
    },
    {
      "src": "/product/([a-z0-9-]+)/?",
      "dest": "/product.php?slug=$1"
    },
    {
      "src": "/wishlist/?",
      "dest": "/wishlist.php"
    }
  ]
}
